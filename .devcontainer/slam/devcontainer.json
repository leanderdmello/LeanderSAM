{
	"name": "SLAM container development environment",
	"build": {
		"dockerfile": "Dockerfile",
		"context": "../.."
	},
	"postCreateCommand": "bash -lc './.devcontainer/setup.bash slam && mkdir -p /workspaces/telerob-main/julia && julia /workspaces/telerob-main/julia/install_packages.jl'",
	"runArgs": [
		"--privileged"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.cpptools-extension-pack",
				"rioj7.command-variable",
				"Ranch-Hand-Robotics.rde-ros-2",
				"eamodio.gitlens"
			]
		}
	},
	"features": {
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
	}
}